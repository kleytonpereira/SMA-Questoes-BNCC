# URL do servidor Ollama local
OLLAMA_BASE_URL=http://localhost:11434

# Modelos por agente (troque para comparar modelos 4B)
GENERATOR_MODEL=qwen3:4b
EVALUATOR_MODEL=qwen3:4b
STRONG_EVALUATOR_MODEL=gemma4:12b
ORGANIZER_MODEL=qwen3:4b

# Auto-consistência do verificador
VERIFIER_SAMPLES=3
VERIFIER_TEMPERATURE=0.7

# Regra opcional de termos absolutos (desligada por padrão)
REGRA_TERMOS_ABSOLUTOS=false

# LangSmith (opcional) - preencha com suas chaves
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT="Gerador de questão"
